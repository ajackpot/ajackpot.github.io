  "benchmark": "stage18-wld-pre-exact-root-benchmark",
  "description": "Benchmark and adoption review for a strict root-only WLD pre-exact mode. The implementation only triggers outside the exact boundary and never mixes WLD with depth-limited or exact subtree search. Range +1 was benchmarked against exact references on 17-empty roots; range +2 was screened on 18-empty roots but not adopted by default.",
  "adoptionDecision": {
    "adopted": true,
    "adoptedWldPreExactEmpties": 1,
    "defaultActivationRule": "Enable by default only when maxDepth >= 8 or timeLimitMs >= 3000; otherwise default to 0 unless explicitly overridden for testing.",
    "rejectedRange2": true,
    "rejectedRange2Reason": "18-empty WLD often finished faster than the deep depth-limited baseline, but the sampled move changed on one case and we do not yet have enough exact move-quality references to justify a +2 default."
  },
