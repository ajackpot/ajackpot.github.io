{
  "name": "tuple-patch-suite-patch-plus-bench",
  "outputDir": "tools/evaluator-training/out/tuple-patch-suite-bench",
  "moduleFormat": "compact",
  "targetScale": 3000,
  "progressEvery": 250000,
  "sharedProfiles": {
    "evaluationProfileJson": "active",
    "moveOrderingProfileJson": "active",
    "mpcProfileJson": "active"
  },
  "benchmarkBaseline": {
    "evaluationProfileJson": "active",
    "moveOrderingProfileJson": "active",
    "tupleProfileJson": "active"
  },
  "defaults": {
    "sourceProfileKind": "auto",
    "tupleScore": "sum-abs",
    "globalScale": 1,
    "calibration": {
      "enabled": true,
      "scope": "holdout-selected",
      "shrink": 1.0,
      "maxBiasStones": 1.5,
      "limit": null
    },
    "exportModule": true,
    "benchmarks": {
      "profile": {
        "enabled": true,
        "limit": 50000,
        "benchmarkLoops": 200
      },
      "depth": {
        "enabled": true,
        "empties": [18, 20, 24],
        "seedStart": 1,
        "seedCount": 8,
        "repetitions": 1,
        "timeLimitMs": 2000,
        "maxDepth": 6,
        "exactEndgameEmpties": 10
      },
      "exact": {
        "enabled": true,
        "empties": [10, 12, 14],
        "seedStart": 1,
        "seedCount": 8,
        "repetitions": 1,
        "timeLimitMs": 60000,
        "maxDepth": 12
      }
    }
  },
  "candidates": [
    {
      "key": "active-lateb-attenuated",
      "name": "active tuple late-b attenuated",
      "sourceTupleProfileJson": "active",
      "bucketScales": { "late-b": 0.75 }
    },
    {
      "key": "diagonal-lite-top24",
      "name": "diagonal top24 + late-b 0.5x",
      "sourceCandidateKey": "diagonal-adjacent-pairs-full-v1",
      "keepTopTuples": 24,
      "bucketScales": { "late-b": 0.5 }
    },
    {
      "key": "diagonal-latea-endgame-top16",
      "name": "diagonal late-a+endgame top16",
      "sourceCandidateKey": "diagonal-adjacent-pairs-full-v1",
      "keepBuckets": ["late-a", "endgame"],
      "keepTopTuples": 16
    },
    {
      "key": "straight-lite-top24",
      "name": "straight top24 + late-b 0.5x",
      "sourceCandidateKey": "straight-adjacent-pairs-full-v1",
      "keepTopTuples": 24,
      "bucketScales": { "late-b": 0.5 }
    },
    {
      "key": "orthogonal-endgame-top16",
      "name": "orthogonal endgame top16",
      "sourceCandidateKey": "orthogonal-adjacent-pairs-full-v1",
      "keepBuckets": ["endgame"],
      "keepTopTuples": 16
    }
  ]
}
